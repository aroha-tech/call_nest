# Example only — copy to `.env` on the server and fill real values. Never commit `.env`.
PORT=4000
NODE_ENV=production

JWT_SECRET=change-me-long-random-string
JWT_REFRESH_SECRET=change-me-different-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE
# OR individual DB params:
DB_HOST=
DB_PORT=4000
DB_NAME=call_nest
DB_USER=
DB_PASSWORD=
DB_SSL=true

SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-me
WHATSAPP_STATUS_CALLBACK_URL=

FRONTEND_URL=https://your-domain.com
API_BASE_URL=https://your-domain.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/api/tenant/email/oauth/google/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT=common
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://your-domain.com/api/tenant/email/oauth/outlook/callback

API_BOOTSTRAP_HOSTS=
CORS_ORIGINS=
CORS_ORIGIN_SUFFIX=

WEB_PUSH_VAPID_SUBJECT=
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
