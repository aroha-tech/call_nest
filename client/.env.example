# Frontend environment (copy to .env for dev)
# Vite exposes only variables prefixed with VITE_

# API base URL (optional)
# Dev: leave empty to use Vite proxy (localhost:3000 -> backend 4000), or set http://localhost:4000 to hit backend directly
# Production (set in .env.production): e.g. https://acme.arohva.com for tenant subdomain
VITE_API_BASE_URL=

# Optional: max CSV import size in MB for client-side checks (match server CSV_IMPORT_MAX_FILE_BYTES)
# VITE_CSV_IMPORT_MAX_MB=5
