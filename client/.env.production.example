# =============================================================================
# PRODUCTION — copy to `client/.env.production` then: npm run build
# =============================================================================
# Output: client/dist — deploy behind nginx on the same host as the API.

VITE_APP_ENV=production

# Same origin as the website (nginx proxies /api to Node) — keep empty:
VITE_API_BASE_URL=https://api.arohva.com

# Only if API is on another host:
# VITE_API_BASE_URL=https://api.yourdomain.com

VITE_CSV_IMPORT_MAX_MB=5
