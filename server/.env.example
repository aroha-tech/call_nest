# Server environment (copy to .env for dev, .env.production for production)
NODE_ENV=development
PORT=4000

# JWT
JWT_SECRET=change-in-production
JWT_REFRESH_SECRET=change-refresh-secret-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Database (use DATABASE_URL OR individual params)
# DATABASE_URL=mysql://user:password@localhost:3306/call_nest
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=call_nest

# Super Admin
SUPER_ADMIN_EMAIL=admin@callnest.com
SUPER_ADMIN_PASSWORD=ChangeMe123!

# WhatsApp status webhook (optional)
# Dev: your ngrok URL. Production: tenant subdomain e.g. https://acme.arohva.com/api/whatsapp/webhook/message-status
WHATSAPP_STATUS_CALLBACK_URL=

# Email OAuth (Gmail / Microsoft Outlook)
# Frontend URL for redirect after Connect with Google/Microsoft (e.g. http://localhost:3000)
FRONTEND_URL=http://localhost:3000
# Base URL of this API for OAuth callback (e.g. http://localhost:4000)
API_BASE_URL=http://localhost:4000

# Gmail: create OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Add redirect URI: {API_BASE_URL}/api/tenant/email/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=  # optional; defaults to API_BASE_URL + /api/tenant/email/oauth/google/callback

# Microsoft: create app at https://portal.azure.com -> App registrations
# Add redirect URI: {API_BASE_URL}/api/tenant/email/oauth/outlook/callback
# API permissions: IMAP.AccessAsUser.All, SMTP.Send (or add scope in token request)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# MICROSOFT_REDIRECT_URI=  # optional
# MICROSOFT_TENANT=common  # common | organizations | consumers | tenant-guid
